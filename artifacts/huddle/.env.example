# Firebase client config (public client values, safe for frontend)
VITE_FIREBASE_API_KEY=replace_me
VITE_FIREBASE_AUTH_DOMAIN=replace_me
VITE_FIREBASE_PROJECT_ID=replace_me
VITE_FIREBASE_STORAGE_BUCKET=replace_me
VITE_FIREBASE_MESSAGING_SENDER_ID=replace_me
VITE_FIREBASE_APP_ID=replace_me

# Optional frontend runtime values
# BASE_PATH=/
# PORT=5173
VITE_FIREBASE_API_KEY=...
VITE_FIREBASE_AUTH_DOMAIN=...
VITE_FIREBASE_PROJECT_ID=...
VITE_FIREBASE_STORAGE_BUCKET=...
VITE_FIREBASE_MESSAGING_SENDER_ID=...
VITE_FIREBASE_APP_ID=...

# Optional ad configuration (web)
# Set VITE_ADS_ENABLED=false to disable all ad slots.
VITE_ADS_ENABLED=true
# AdSense publisher id, e.g. ca-pub-xxxxxxxxxxxxxxxx
VITE_ADSENSE_CLIENT=
VITE_ADSENSE_SLOT_INLINE=
VITE_ADSENSE_SLOT_RAIL=
VITE_ADSENSE_SLOT_MOBILE=
