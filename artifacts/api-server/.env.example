PORT=8080

# Anthropic integration (used by /api/ai, meal photo analysis, and AI price refresh)
# Base URL should be host only (no trailing /v1), because routes append /v1/messages.
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=replace_me

# Paid-feature gate for meal photo analysis.
# false = available to everyone (current rollout mode)
# true  = requires creditsAvailable >= 1 in request body
REQUIRE_MEAL_PHOTO_CREDITS=false

# Optional: Google Calendar OAuth integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
