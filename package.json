{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs');['package-lock.json','yarn.lock'].forEach((f)=>{try{fs.rmSync(f,{force:true});}catch{}});const ua=process.env.npm_config_user_agent||'';if(!ua.startsWith('pnpm/')){console.error('Use pnpm instead');process.exit(1);}\"",
    "dev:check": "node ./scripts/check-dev-setup.mjs",
    "dev:api": "cross-env PORT=8080 DATABASE_URL=postgresql://ubuntu:ubuntu@localhost:5432/huddle pnpm --filter @workspace/api-server run dev",
    "dev:web": "cross-env PORT=5173 pnpm --filter @workspace/huddle run dev",
    "dev": "npm run dev:check && concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "pnpm": "^10.33.0",
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
